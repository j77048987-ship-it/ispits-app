{
  "name": "ispits-prep-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first exam-prep platform for the Moroccan ISPITS entrance exam (SVT + Français), built as a PWA and wrapped for Android with Capacitor.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "validate:questions": "tsx scripts/validate-questions.ts",
    "cap:sync": "cap sync android",
    "cap:open:android": "cap open android",
    "cap:add:android": "cap add android"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "i18next": "^24.0.0",
    "dexie": "^4.0.0",
    "dexie-react-hooks": "^1.1.7",
    "recharts": "^2.13.0",
    "lucide-react": "^0.460.0",
    "jspdf": "^2.5.2",
    "@capacitor/core": "^8.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/app": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.0.0",
    "tsx": "^4.19.0",
    "eslint": "^9.13.0",
    "@eslint/js": "^9.13.0",
    "typescript-eslint": "^8.11.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
